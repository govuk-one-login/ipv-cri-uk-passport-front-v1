{
  "mappings": [
    {
      "scenarioName": "passport-session-error",
      "request": {
        "method": "GET",
        "url": "/__reset/passport-session-error"
      },
      "response": {
        "status": 200
      }
    },
    {
      "scenarioName": "passport-session-error",
      "request": {
        "method": "POST",
        "urlPath": "/session",
        "headers": {
          "x-scenario-id": {
            "equalTo": "passport-session-error"
          }
        }
      },
      "response": {
        "status": 500
      }
    },
    {
      "scenarioName": "passport-session-error",
      "request": {
        "method": "GET",
        "urlPathPattern": "/return.*",
        "queryParameters": {
          "error": {
            "equalTo": "server_error"
          },
          "error_description": {
            "equalTo": "general error"
          }
        }
      },
      "response": {
        "status": 200,
        "body": "OAuth error callback received"
      }
    }
  ]
}
