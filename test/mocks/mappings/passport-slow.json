        "url": "/__reset/passport-success-slow"
      },
      "response": {
        "status": 200
      }
    },
    {
      "scenarioName": "passport-success-slow",
      "request": {
        "method": "POST",
        "urlPath": "/session",
        "headers": {
          "x-scenario-id": {
            "equalTo": "passport-success-slow"
          }
        }
      },
      "response": {
        "status": 200,
        "jsonBody": {
          "session_id": "ABADCAFE",
          "state": "sT@t3",
          "redirect_uri": "http://localhost:8050/return"
        }
      }
    },
    {
      "scenarioName": "passport-success-slow",
      "request": {
        "method": "POST",
        "urlPath": "/check-passport",
        "headers": {
          "x-scenario-id": {
            "equalTo": "passport-success-slow"
          },
          "session_id": {
            "equalTo": "ABADCAFE"
          }
        }
      },
      "response": {
        "fixedDelayMilliseconds": "5000",
        "status": 200
      }
    },
    {
      "scenarioName": "passport-success-slow",
      "request": {
        "method": "GET",
        "urlPath": "/authorization",
        "headers": {
          "x-scenario-id": {
            "equalTo": "passport-success-slow"
          },
          "session_id": {
            "equalTo": "ABADCAFE"
          }
        }
      },
      "response": {
        "status": 200,
        "jsonBody": {
          "authorizationCode": {
            "value": "FACEFEED"
          }
        }
      }
    },
    {
      "scenarioName": "passport-success-slow",
      "request": {
        "method": "GET",
        "urlPathPattern": "/return.*",
        "queryParameters": {
          "client_id": {
            "equalTo": "standalone"
          },
          "state": {
            "equalTo": "sT@t3"
          },
          "code": {
            "equalTo": "FACEFEED"
          }
        }
      },
      "response": {
        "status": 200,
        "body": "OAuth callback received successfully"
      }
    }
  ]
